{
  "name": "mi-app-electron",
  "version": "1.0.0",
  "description": "Electron by bun",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun build ./src/main.ts ./src/preload.ts ./src/renderer.ts --outdir ./dist --target node --format cjs --external electron",
    "build:watch": "bun build ./src/main.ts ./src/preload.ts ./src/renderer.ts --outdir ./dist --target node --format cjs --external electron --watch",
    "start": "bun run build && electron .",
    "dev": "concurrently \"bun:build:watch\" \"electron . --inspect=5858\"",
    "pack": "bun run build && electron-builder --dir",
    "dist": "bun run build && electron-builder",
    "dist:win": "bun run build && electron-builder --win",
    "dist:mac": "bun run build && electron-builder --mac",
    "dist:linux": "bun run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.business.mi-app-electron",
    "productName": "My App Name",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "src-ui/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icons",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": "Tu Nombre <tu@email.com>",
  "devDependencies": {
    "@types/chokidar": "^2.1.7",
    "@types/node": "^20.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.0"
  }
}